---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<footer id="footer">
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <a href={`/${lang}/`} class="footer-logo">VK<span>.</span></a>
        <p class="footer-tagline">{t('footer.tagline')}</p>
      </div>
      <nav class="footer-nav">
        <div class="footer-nav-col">
          <span class="footer-nav-label">{t('footer.pages')}</span>
          <a href={`/${lang}/`}>{t('nav.home')}</a>
          <a href={`/${lang}/about`}>{t('nav.about')}</a>
          <a href={`/${lang}/services`}>{t('nav.services')}</a>
          <a href={`/${lang}/portfolio`}>{t('nav.works')}</a>
          <a href={`/${lang}/contact`}>{t('nav.contact')}</a>
        </div>
        <div class="footer-nav-col">
          <span class="footer-nav-label">{t('footer.social')}</span>
          <a href="https://github.com/vkesgin" target="_blank" rel="noopener">GitHub</a>
          <a href="https://www.linkedin.com/in/veli-kesgin-9b226014b" target="_blank" rel="noopener">LinkedIn</a>
          <a href="https://instagram.com/veli.ksgn" target="_blank" rel="noopener">Instagram</a>
          <a href="https://www.behance.net/velikesgin" target="_blank" rel="noopener">Behance</a>
        </div>
        <div class="footer-nav-col">
          <span class="footer-nav-label">{t('footer.contact')}</span>
          <a href="mailto:veli@velikesgin.com">veli@velikesgin.com</a>
          <a href={`/${lang}/contact`}>{t('footer.offer')}</a>
        </div>
      </nav>
    </div>
    
    <div class="footer-tools-section">
      <p class="footer-tools-label">{t('footer.tools')}</p>
      <div class="footer-tools-grid">
        <a href="/tool-pdf.html" class="footer-tool-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
          <span>PDF</span>
        </a>
        <a href="/tool-audio.html" class="footer-tool-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"></path><path d="M19 10v2a7 7 0 0 1-14 0v-2"></path><line x1="12" y1="19" x2="12" y2="23"></line><line x1="8" y1="23" x2="16" y2="23"></line></svg>
          <span>Audio</span>
        </a>
        <a href="/tool-bg-remover.html" class="footer-tool-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3h18v18H3z"></path><path d="M12 8v8"></path><path d="M8 12h8"></path></svg>
          <span>BG Remove</span>
        </a>
      </div>
    </div>
    
    <div class="footer-big-text">
      <span class="footer-word" data-text="VELİ">VELİ</span>
      <span class="footer-word footer-word--outline" data-text="KESGİN">KESGİN</span>
    </div>
    <div class="footer-bottom">
      <span class="footer-copy">© 2026 Veli Kesgin — {t('footer.rights')}</span>
      <span class="footer-made">{t('footer.made')} - <span style="color:var(--accent)">Veli Kesgin</span></span>
    </div>
  </div>
  <div class="footer-glow"></div>
</footer>
