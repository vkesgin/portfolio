---
import MainLayout from '../../layouts/MainLayout.astro';
import { getLangFromUrl } from '../../i18n/utils';
import { ui } from '../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(ui).map(lang => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);

const c = {
  tr: {
    title: "Hizmetler — Veli Kesgin | Web Design, 3D & Videografi",
    eyebrow1: "// hizmetler",
    heroTitle1: "NE",
    heroTitle2: "SUNUYORUM",
    heroSub: "Tek bir disiplin değil — tam spektrum yaratıcı üretim.<br>Fikir aşamasından teslimata kadar her şeyi burada bulursun.",
    scrollHint: "6 HİZMET",
    services: [
      { num: "01", name: "Web Design", tag: "İnteraktif · Animasyonlu · Özgün" },
      { num: "02", name: "Grafik Tasarım", tag: "Kimlik · Baskı · Dijital" },
      { num: "03", name: "2D Animasyon", tag: "Motion · Karakter · Explainer" },
      { num: "04", name: "3D Animasyon", tag: "Modelleme · Render · Sinematik" },
      { num: "05", name: "Videografi", tag: "Çekim · Kurgu · Color Grade" },
      { num: "06", name: "Yazılım", tag: "Frontend · Uygulama · Araç" }
    ],
    ctaBtn: "Teklif Al ↗",
    processEyebrow: "// çalışma süreci",
    processTitle: "NASIL<br><span class=\"outline-text\">ÇALIŞIYORUM</span>",
    process: [
      { title: "Keşif", desc: "Projeyi, hedef kitleyi ve beklentileri anlamak için detaylı bir brifing toplantısı yapıyoruz." },
      { title: "Strateji", desc: "Konsept, zaman planı ve teknik yaklaşımı belirliyor, onaylatıyorum." },
      { title: "Üretim", desc: "Tasarım ve geliştirme sürecinde düzenli güncellemeler paylaşıyorum." },
      { title: "Teslim", desc: "Revizyon turları sonrası nihai teslimat ve gerekirse yayına alma desteği." }
    ],
    ctaMainTitle: "PROJENİ<br><span class=\"outline-text\">BAŞLATALIM</span>",
    ctaMainSub: "Fikrin var, sen anlat — gerisini halledelim.",
    ctaMainBtn: "İletişime Geç ↗"
  },
  en: {
    title: "Services — Veli Kesgin | Web Design, 3D & Videography",
    eyebrow1: "// services",
    heroTitle1: "WHAT",
    heroTitle2: "I OFFER",
    heroSub: "Not a single discipline — full spectrum creative production.<br>You'll find everything here from idea to delivery.",
    scrollHint: "6 SERVICES",
    services: [
      { num: "01", name: "Web Design", tag: "Interactive · Animated · Unique" },
      { num: "02", name: "Graphic Design", tag: "Identity · Print · Digital" },
      { num: "03", name: "2D Animation", tag: "Motion · Character · Explainer" },
      { num: "04", name: "3D Animation", tag: "Modeling · Render · Cinematic" },
      { num: "05", name: "Videography", tag: "Shooting · Edit · Color Grade" },
      { num: "06", name: "Development", tag: "Frontend · App · Tools" }
    ],
    ctaBtn: "Get Quote ↗",
    processEyebrow: "// working process",
    processTitle: "HOW<br><span class=\"outline-text\">I WORK</span>",
    process: [
      { title: "Discovery", desc: "We hold a detailed briefing meeting to understand the project, target audience and expectations." },
      { title: "Strategy", desc: "I define the concept, timeline and technical approach, and get your approval." },
      { title: "Production", desc: "I share regular updates during the design and development process." },
      { title: "Delivery", desc: "Final delivery after revision rounds and deployment support if needed." }
    ],
    ctaMainTitle: "LET'S START<br><span class=\"outline-text\">YOUR PROJECT</span>",
    ctaMainSub: "You have an idea, tell it — let us handle the rest.",
    ctaMainBtn: "Contact Me ↗"
  }
}[lang];
---
<MainLayout title={c.title}>
  <section id="srv-hero">
    <div class="srv-hero-inner">
      <p class="section-eyebrow srv-eyebrow">{c.eyebrow1}</p>
      <h1 class="srv-hero-title">
        <span class="srv-line">{c.heroTitle1}</span>
        <span class="srv-line srv-line--outline">{c.heroTitle2}</span>
      </h1>
      <p class="srv-hero-sub" set:html={c.heroSub}></p>
    </div>
    <div class="srv-hero-scroll-hint">
      <span>{c.scrollHint}</span>
      <div class="scroll-track"><div class="scroll-thumb"></div></div>
    </div>
  </section>

  <section id="srv-list">
    <div class="srv-list-inner">
      <div class="srv-item" id="web">
        <div class="srv-item-head">
          <div class="srv-item-left">
            <span class="srv-num">{c.services[0].num}</span>
            <div>
              <h2 class="srv-name">{c.services[0].name}</h2>
              <p class="srv-tagline">{c.services[0].tag}</p>
            </div>
          </div>
          <div class="srv-icon">
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none"><rect x="3" y="6" width="30" height="20" rx="2.5" stroke="currentColor" stroke-width="1.2" /><path d="M11 14l4 4-4 4M19 22h7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" /><path d="M3 30h30" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity=".3" /></svg>
          </div>
        </div>
        <div class="srv-item-body">
          <div class="srv-desc-col">
            <p class="srv-desc">
              Ziyaretçinin ilk saniyede etkilendiği, scroll'u bırakmak istemediği web siteleri tasarlıyorum. GSAP, Three.js ve özel animasyon sistemleriyle hayata geçirilen, hem görsel hem teknik açıdan üst düzey arayüzler.
            </p>
            <ul class="srv-includes">
              <li>Özel tasarım — hazır tema yok</li><li>Scroll & hover animasyonları</li><li>Three.js / Canvas efektleri</li><li>Tam responsive, mobil öncelikli</li><li>SEO temelli HTML yapısı</li><li>Cloudflare / hosting deploy</li>
            </ul>
          </div>
          <div class="srv-tags-col">
            <span class="srv-tag">HTML · CSS · JS</span><span class="srv-tag">GSAP</span><span class="srv-tag">Three.js</span><span class="srv-tag">UI/UX</span>
            <a href={`/${lang}/contact`} class="srv-cta-btn">{c.ctaBtn}</a>
          </div>
        </div>
      </div>

      <div class="srv-item" id="graphic">
        <div class="srv-item-head">
          <div class="srv-item-left">
            <span class="srv-num">{c.services[1].num}</span>
            <div>
              <h2 class="srv-name">{c.services[1].name}</h2>
              <p class="srv-tagline">{c.services[1].tag}</p>
            </div>
          </div>
          <div class="srv-icon">
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none"><circle cx="18" cy="18" r="7" stroke="currentColor" stroke-width="1.2" /><path d="M18 3v6M18 27v6M3 18h6M27 18h6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" /><circle cx="18" cy="18" r="14" stroke="currentColor" stroke-width="1.2" stroke-dasharray="2.5 3.5" opacity=".35" /></svg>
          </div>
        </div>
        <div class="srv-item-body">
          <div class="srv-desc-col">
            <p class="srv-desc">Markanın görsel kimliğini sıfırdan inşa ediyorum. Logo, renk sistemi, tipografi rehberi ve tüm temas noktalarında tutarlı, özgün bir dil.</p>
            <ul class="srv-includes"><li>Logo tasarımı & varyasyonlar</li><li>Kurumsal kimlik rehberi</li><li>Sosyal medya şablonları</li><li>Baskı tasarımı</li></ul>
          </div>
          <div class="srv-tags-col">
            <span class="srv-tag">Illustrator</span><span class="srv-tag">Photoshop</span><span class="srv-tag">Branding</span><span class="srv-tag">Print</span>
            <a href={`/${lang}/contact`} class="srv-cta-btn">{c.ctaBtn}</a>
          </div>
        </div>
      </div>

      <div class="srv-item" id="2d">
        <div class="srv-item-head">
          <div class="srv-item-left">
            <span class="srv-num">{c.services[2].num}</span>
            <div>
              <h2 class="srv-name">{c.services[2].name}</h2>
              <p class="srv-tagline">{c.services[2].tag}</p>
            </div>
          </div>
          <div class="srv-icon">
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none"><path d="M4 28 Q10 8 18 16 Q26 24 32 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" fill="none" /><circle cx="10" cy="22" r="3" stroke="currentColor" stroke-width="1.2" /><circle cx="26" cy="10" r="3" stroke="currentColor" stroke-width="1.2" /><path d="M4 32h28" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity=".3" /></svg>
          </div>
        </div>
        <div class="srv-item-body">
          <div class="srv-desc-col">
            <p class="srv-desc">Karmaşık fikirleri hareketli görsellerle basit ve etkileyici hale getiriyorum. Karakter animasyonu, motion graphics ve explainer video.</p>
            <ul class="srv-includes"><li>Karakter tasarımı & rigging</li><li>Explainer video</li><li>Motion graphics</li><li>Logo animasyonu</li></ul>
          </div>
          <div class="srv-tags-col">
            <span class="srv-tag">After Effects</span><span class="srv-tag">Lottie</span><span class="srv-tag">Motion</span>
            <a href={`/${lang}/contact`} class="srv-cta-btn">{c.ctaBtn}</a>
          </div>
        </div>
      </div>

      <div class="srv-item" id="3d">
        <div class="srv-item-head">
          <div class="srv-item-left">
            <span class="srv-num">{c.services[3].num}</span>
            <div>
              <h2 class="srv-name">{c.services[3].name}</h2>
              <p class="srv-tagline">{c.services[3].tag}</p>
            </div>
          </div>
          <div class="srv-icon">
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none"><path d="M18 3L33 12v12L18 33 3 24V12z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round" /><path d="M18 3v30M3 12l15 9 15-9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" /></svg>
          </div>
        </div>
        <div class="srv-item-body">
          <div class="srv-desc-col">
            <p class="srv-desc">Ürünleri, mekanları ve fikirleri üç boyutlu dünyada hayata geçiriyorum. Fotogerçekçi render'dan stilize animasyona, ürün görselleştirmesinden sinematik sekansa kadar tam prodüksiyon.</p>
            <ul class="srv-includes"><li>3D modelleme & texturing</li><li>Ürün görselleştirme</li><li>Mimari & mekan render</li><li>Sinematik animasyon</li></ul>
          </div>
          <div class="srv-tags-col">
            <span class="srv-tag">Blender</span><span class="srv-tag">Cinema 4D</span><span class="srv-tag">Render</span><span class="srv-tag">VFX</span>
            <a href={`/${lang}/contact`} class="srv-cta-btn">{c.ctaBtn}</a>
          </div>
        </div>
      </div>

      <div class="srv-item" id="video">
        <div class="srv-item-head">
          <div class="srv-item-left">
            <span class="srv-num">{c.services[4].num}</span>
            <div>
              <h2 class="srv-name">{c.services[4].name}</h2>
              <p class="srv-tagline">{c.services[4].tag}</p>
            </div>
          </div>
          <div class="srv-icon">
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none"><rect x="3" y="8" width="22" height="18" rx="2.5" stroke="currentColor" stroke-width="1.2" /><path d="M25 15l8-5v14l-8-5" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round" /><circle cx="14" cy="17" r="4" stroke="currentColor" stroke-width="1.2" /></svg>
          </div>
        </div>
        <div class="srv-item-body">
          <div class="srv-desc-col">
            <p class="srv-desc">Sahne planlamasından kurguya, renk düzenlemeye kadar eksiksiz video prodüksiyonu. Kurumsal tanıtım, ürün videosu, sosyal medya içeriği.</p>
            <ul class="srv-includes"><li>Konsept & senaryo</li><li>Profesyonel çekim</li><li>Kurgu & ses</li><li>Color grading</li></ul>
          </div>
          <div class="srv-tags-col">
            <span class="srv-tag">Premiere Pro</span><span class="srv-tag">DaVinci</span><span class="srv-tag">4K</span>
            <a href={`/${lang}/contact`} class="srv-cta-btn">{c.ctaBtn}</a>
          </div>
        </div>
      </div>

      <div class="srv-item" id="code">
        <div class="srv-item-head">
          <div class="srv-item-left">
            <span class="srv-num">{c.services[5].num}</span>
            <div>
              <h2 class="srv-name">{c.services[5].name}</h2>
              <p class="srv-tagline">{c.services[5].tag}</p>
            </div>
          </div>
          <div class="srv-icon">
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none"><path d="M10 12l-7 6 7 6M26 12l7 6-7 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" /><path d="M21 6l-6 24" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" /></svg>
          </div>
        </div>
        <div class="srv-item-body">
          <div class="srv-desc-col">
            <p class="srv-desc">Tasarımın ötesine geçen, gerçekten çalışan ürünler geliştiriyorum. İnteraktif web uygulamaları, özel araçlar ve API entegrasyonları — temiz kod, iyi mimari, ölçeklenebilir yapı.</p>
            <ul class="srv-includes"><li>Frontend geliştirme</li><li>İnteraktif web uygulamaları</li><li>API entegrasyonu</li><li>Performans optimizasyonu</li></ul>
          </div>
          <div class="srv-tags-col">
            <span class="srv-tag">HTML/CSS/JS</span><span class="srv-tag">React</span><span class="srv-tag">API</span>
            <a href={`/${lang}/contact`} class="srv-cta-btn">{c.ctaBtn}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="srv-process">
    <div class="srv-process-inner">
      <p class="section-eyebrow">{c.processEyebrow}</p>
      <h2 class="section-title" set:html={c.processTitle}></h2>
      <div class="process-grid">
        {c.process.map((step, i) => (
          <div class="process-step">
            <span class="process-num">0{i + 1}</span>
            <h3 class="process-title">{step.title}</h3>
            <p class="process-desc">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="srv-cta">
    <div class="srv-cta-inner">
      <h2 class="srv-cta-title" set:html={c.ctaMainTitle}></h2>
      <p class="srv-cta-sub">{c.ctaMainSub}</p>
      <a href={`/${lang}/contact`} class="btn btn-primary" style="font-size:13px;padding:16px 44px;letter-spacing:.12em">{c.ctaMainBtn}</a>
    </div>
  </section>

  <Fragment slot="head">
    <link rel="stylesheet" href="/assets/css/services.css">
  </Fragment>

  <Fragment slot="scripts">
    <script src="/assets/js/services.js" is:inline></script>
  </Fragment>
</MainLayout>
